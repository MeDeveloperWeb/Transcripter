generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Recording {
  id        String   @id @default(cuid())
  status    String   @default("recording") // recording | completed | failed
  duration  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt    DateTime     @updatedAt
  chunks       Chunk[]
  transcripts  Transcript[]

  @@map("recordings")
}

model Chunk {
  id          String      @id @default(cuid())
  recordingId String
  recording   Recording   @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  sequence    Int
  bucketPath  String?
  duration    Float
  size        Int
  status      String      @default("pending") // pending | uploaded | acked | failed
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  transcript  Transcript?

  @@unique([recordingId, sequence])
  @@index([recordingId, status])
  @@map("chunks")
}

model Transcript {
  id          String    @id @default(cuid())
  chunkId     String    @unique
  chunk       Chunk     @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  text        String    @default("")
  utterances  Json      @default("[]") // [{ speaker: number, text: string, start: number, end: number }]
  status      String    @default("pending") // pending | processing | completed | failed
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([recordingId])
  @@map("transcripts")
}
