# Supabase Postgres
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=10"

# S3-compatible Storage (Supabase Storage S3 gateway)
S3_ENDPOINT="https://[PROJECT_REF].storage.supabase.co/storage/v1/s3"
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"
S3_BUCKET_NAME="your-bucket-name"

# Deepgram
DEEPGRAM_API_KEY="your-deepgram-api-key"

# App
CORS_ORIGIN="http://localhost:3001"
NODE_ENV="development"
